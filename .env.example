# Foundry VTT credentials (required for Docker deployment)
FOUNDRY_USERNAME=your-foundry-username
FOUNDRY_PASSWORD=your-foundry-password

# Path to Foundry VTT data directory on the host.
#
# - Production (docker-compose.yml / docker-compose.dev.yml): required;
#   typically a Linux path on the dedicated host, e.g. /home/alex/foundrydata.
# - Local Docker Desktop (docker-compose.local.yml): optional. If unset,
#   a named Docker volume (foundry-data-local) is used automatically, which
#   is the portable default. Set a host path here (Windows, macOS, or Linux)
#   if you want filesystem access to the world data.
FOUNDRY_DATA=/path/to/foundrydata

# OpenAI API key (required for edit_image tool - GPT-image-1)
OPENAI_API_KEY=sk-your-openai-api-key

# Local-only port overrides (docker-compose.local.yml).
# Uncomment to run alongside a production container on the same machine.
# FOUNDRY_PORT=30010
# MCP_PORT=8775
