{
  "version": "2.0.0",
  "tasks": [
    //  ─── Local Docker ─────────────────────────────────────────────────────
    {
      "label": "local: up",
      "detail": "First-time: build image + start container via local.sh",
      "type": "shell",
      "command": "./local.sh up",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": { "executable": "bash", "args": ["-c"] }
      },
      "windows": {
        "options": {
          "cwd": "${workspaceFolder}",
          "shell": { "executable": "${env:PROGRAMFILES}\\Git\\bin\\bash.exe", "args": ["-c"] }
        }
      },
      "problemMatcher": []
    },
    {
      "label": "local: rebuild",
      "detail": "Rebuild module + server dist, restart container",
      "type": "shell",
      "command": "./local.sh rebuild",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": { "executable": "bash", "args": ["-c"] }
      },
      "windows": {
        "options": {
          "cwd": "${workspaceFolder}",
          "shell": { "executable": "${env:PROGRAMFILES}\\Git\\bin\\bash.exe", "args": ["-c"] }
        }
      },
      "problemMatcher": []
    },
    {
      //  Faster iteration path for MCP-only changes: rebuilds just the
      //  server dist (tsc) and restarts the container so the new JS is
      //  picked up. Skips the module/vite build since the module is
      //  bind-mounted and updates live in the browser. Used as the
      //  preLaunchTask for "Debug MCP server (full stack)".
      //
      //  Composed via dependsOn so each step runs in whatever default
      //  shell VS Code picks (PowerShell on Windows, zsh on macOS) —
      //  no bash override that can collide with WSL's bash.exe on PATH.
      "label": "local: server-rebuild",
      "detail": "Build server dist + ensure container is up + restart (fast MCP iteration)",
      "dependsOn": ["server: build", "local: start", "local: restart"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "server: build",
      "detail": "tsc → server/dist (sub-task of local: server-rebuild)",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/server" },
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "silent", "revealProblems": "onProblem" }
    },
    {
      "label": "local: restart",
      "detail": "docker compose restart (sub-task of local: server-rebuild)",
      "type": "shell",
      "command": "docker compose -f docker-compose.local.yml restart",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "local: start",
      "detail": "Start container without rebuilding",
      "type": "shell",
      "command": "docker compose -f docker-compose.local.yml up -d",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "local: stop",
      "type": "shell",
      "command": "docker compose -f docker-compose.local.yml stop",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "local: logs",
      "detail": "Tail container logs (dedicated terminal)",
      "type": "shell",
      "command": "docker compose -f docker-compose.local.yml logs -f --tail=100",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "foundrylogs", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "local: status",
      "type": "shell",
      "command": "./local.sh status",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": { "executable": "bash", "args": ["-c"] }
      },
      "windows": {
        "options": {
          "cwd": "${workspaceFolder}",
          "shell": { "executable": "${env:PROGRAMFILES}\\Git\\bin\\bash.exe", "args": ["-c"] }
        }
      },
      "problemMatcher": []
    },
    {
      "label": "local: shell",
      "detail": "Interactive bash inside the container",
      "type": "shell",
      "command": "docker compose -f docker-compose.local.yml exec foundry-local bash",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "problemMatcher": []
    },

    //  ─── Standalone dev watches (no Docker) ──────────────────────────────
    {
      "label": "module: watch",
      "detail": "vite build --watch against module/dist — restart container to load",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/module" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "foundrymodule", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "server: dev (host node)",
      "detail": "tsx dev server on host (bypasses Docker — use for fast MCP-only iteration)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/server" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "foundryserver", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "module: test",
      "type": "shell",
      "command": "npm run test",
      "options": { "cwd": "${workspaceFolder}/module" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "module: typecheck",
      "type": "shell",
      "command": "npm run type-check",
      "options": { "cwd": "${workspaceFolder}/module" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "module: build",
      "detail": "vite build → module/dist (one-shot; pair with local: restart to deploy)",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/module" },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    //  ─── Frontend (React SPA, Vite) ─────────────────────────────────────
    {
      //  Long-running; isBackground + a background problemMatcher lets
      //  VS Code know when Vite has actually finished starting so
      //  preLaunchTask (the Chrome debug config) can proceed to attach
      //  instead of hanging forever waiting for the task to "finish".
      //  Matches Vite's startup banner: `VITE v8.x.x  ready in N ms`.
      "label": "frontend: dev",
      "detail": "Vite dev server on :5173 — proxies /api to foundry-mcp container on :8765",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "frontend", "reveal": "always" },
      "problemMatcher": {
        "owner": "vite",
        "pattern": [{ "regexp": "^$", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*VITE\\s+v",
          "endsPattern": "ready in "
        }
      }
    },
    {
      "label": "frontend: build",
      "detail": "Production build to frontend/dist",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "frontend: test",
      "type": "shell",
      "command": "npm run test",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "frontend: typecheck",
      "type": "shell",
      "command": "npm run typecheck",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "server: typecheck",
      "type": "shell",
      "command": "./node_modules/.bin/tsc --noEmit",
      "options": {
        "cwd": "${workspaceFolder}/server",
        "shell": { "executable": "bash", "args": ["-c"] }
      },
      "windows": {
        "options": {
          "cwd": "${workspaceFolder}/server",
          "shell": { "executable": "${env:PROGRAMFILES}\\Git\\bin\\bash.exe", "args": ["-c"] }
        }
      },
      "problemMatcher": ["$tsc"]
    }
  ]
}
